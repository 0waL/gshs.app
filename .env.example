# Required for Prisma (SQLite local DB)
DATABASE_URL="file:./dev.db"

# Required for next-auth session encryption/signing
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional app/base URL (used by sitemap/robots)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional external integrations (leave empty for local/offline mode)
# Google Analytics is configured from /admin/settings.
NEXT_PUBLIC_NEIS_API_KEY=""
